# ── QA Platform — Environment Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="QA Platform"
APP_VERSION="2.0.0"
DEBUG=false

# ── Security ──────────────────────────────────────────────────────────────────
# Leave empty to disable API key auth (safe for LAN-only deployments).
API_ACCESS_KEY=

# Change this to a long random string in production.
SECRET_KEY=change-me-to-a-long-random-secret

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — no extra setup required)
DATABASE_URL=sqlite:///./database/qa_platform.db

# PostgreSQL example (comment out SQLite line above):
# DATABASE_URL=postgresql://qa_user:password@localhost:5432/qa_platform

# ── Data paths ─────────────────────────────────────────────────────────────────
# Relative to project root; override only if your data lives elsewhere.
# DATA_DIR=/absolute/custom/path/to/data

# ── Service ports ──────────────────────────────────────────────────────────────
FASTAPI_PORT=8000
DASH_PORT=8050

# ── Dashboard → API connection ────────────────────────────────────────────────
# URL the Dash app uses to reach the FastAPI backend.
QA_API_BASE=http://127.0.0.1:8000

# ── Week / Cut-off ────────────────────────────────────────────────────────────
# Set this to skip the interactive prompt when generating reports.
# SEMANA_PROYECTO=S194
# SEMANA_CORTE=S194

# ── CORS (comma-separated origins) ───────────────────────────────────────────
# ALLOWED_ORIGINS=http://your-server.local,https://qa.yourcompany.com
