[Unit]
Description=QA Platform FastAPI Backend
After=network.target

[Service]
Type=simple
User=qa
Group=www-data
WorkingDirectory=/opt/proyecto_dossier
Environment="PYTHONUNBUFFERED=1"
Environment="FASTAPI_PORT=8000"
EnvironmentFile=-/opt/proyecto_dossier/.env
ExecStart=/opt/proyecto_dossier/.venv/bin/uvicorn backend.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
